# ── Anthropic ────────────────────────────────────────────────────────────────
# Powers the chat agent, health-check report writing, and article drafting.
ANTHROPIC_API_KEY=

# ── Database (Vercel Postgres / Neon) ────────────────────────────────────────
# Postgres connection string, e.g. postgres://user:pass@host/db?sslmode=require
DATABASE_URL=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=info@lakecumberlandcomputers.com
LEAD_NOTIFY_EMAIL=louis@lakecumberlandcomputers.com

# ── Stripe (residential payments) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Twilio SMS (optional — if absent, SMS is logged instead of sent) ─────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Microsoft Graph (optional — shared "Service Appointments" calendar) ──────
# App registration with application permission Calendars.ReadWrite, scoped to
# the shared mailbox via an application access policy (see README).
# If absent, availability falls back to DB-only and events are not created.
MSGRAPH_TENANT_ID=
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
# Mailbox (UPN) that owns the "Service Appointments" calendar
MSGRAPH_CALENDAR_USER=

# ── Microsoft Bookings (business/government consults) ────────────────────────
BOOKINGS_URL=

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://lakecumberlandcomputers.com

# ── Admin (content engine at /admin) ─────────────────────────────────────────
# Long random string; entered once at /admin to set the gate cookie.
ADMIN_SECRET=

# ── Cron protection ──────────────────────────────────────────────────────────
# Vercel sends "Authorization: Bearer <CRON_SECRET>" with each cron request.
CRON_SECRET=

# ── Review flywheel ──────────────────────────────────────────────────────────
# TODO(Louis): paste the "Ask for reviews" short link from Google Business
# Profile. Post-appointment review requests are skipped (and logged) until set.
GOOGLE_REVIEW_URL=
